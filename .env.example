# ─────────────────────────────────────────
# Google Cloud Platform
# ─────────────────────────────────────────
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-key.json

# ─────────────────────────────────────────
# MySQL / Cloud SQL
# ─────────────────────────────────────────
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=finance_db

# ─────────────────────────────────────────
# Python FastAPI (Primary Ingestion)
# ─────────────────────────────────────────
PYTHON_API_URL=http://localhost:8000
PYTHON_API_PORT=8000

# ─────────────────────────────────────────
# Node.js Express (Fallback Ingestion)
# ─────────────────────────────────────────
NODE_API_URL=http://localhost:3000
NODE_API_PORT=3000

# ─────────────────────────────────────────
# Streamlit
# ─────────────────────────────────────────
STREAMLIT_PORT=8501
