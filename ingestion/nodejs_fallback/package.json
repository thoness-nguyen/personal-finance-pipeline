{
  "name": "nodejs-fallback",
  "version": "1.0.0",
  "description": "Fallback Node.js ingestion service for the personal finance pipeline",
  "main": "dist/App.js",
  "scripts": {
    "local:run": "ts-node src/services/SpreadsheetService.ts",
    "build": "tsc",
    "start": "node dist/App.js",
    "dev": "nodemon --exec ts-node src/App.ts",
    "test": "jest --forceExit"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "cors": "^2.8.5",
    "csv-stringify": "^6.5.1",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}